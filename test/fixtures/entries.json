        "usages": [
          {
            "id": "3881-1_us0",
            "mid": "cs.3881-1_us0",
            "author": "",
            "copyright": null,
            "source": "http://zpravy.rozhlas.cz/cb/serialy/_zprava/seznamte-se-s-pravymi-sumavskymi-vyrobky-1-az-50-dil--682647",
            "admin": "https://the.sketchengine.co.uk/bonito/run.cgi/first?iquery=v%C4%8Del%C3%AD+vosk&corpname=preloaded%2Fcztenten12_8&corpus-search-form=true",
            "text": {
              "_text": "Výrobky ze včelího vosku jsou stoprocentně přírodní produkt."
            },
            "type": "sentence",
            "updated_at": "2016-02-04 15:20:11",
            "created_at": null,
            "status": "published"
          },
          {
            "id": "3881-1_us1",
            "mid": "cs.3881-1_us1",
            "author": "",
            "copyright": null,
            "source": "http://www.dobra-koupe.cz/zbozi.asp?idshop=2546&amp;from=40",
            "admin": "https://the.sketchengine.co.uk/bonito/run.cgi/first?iquery=vosk&corpname=preloaded%2Fcztenten12_8&corpus-search-form=true",
            "text": {
              "_text": "Bavlněná šňůrka o tloušťce jednoho milimetru potažená voskem je vhodným základem pro váš originální šperk."
            },
            "type": "sentence",
            "updated_at": "2016-02-04 15:20:11",
            "created_at": null,
            "status": "published"
          },
          {
            "id": "3881-1_us2",
            "mid": "cs.3881-1_us2",
            "author": "",
            "copyright": null,
            "source": "http://www.pindici.cz/fashion/?clanek=58",
            "admin": "https://the.sketchengine.co.uk/bonito/run.cgi/first?iquery=vosk&corpname=preloaded%2Fcztenten12_8&corpus-search-form=true",
            "text": {
              "_text": "K tomuto účesu ovšem nutně potřebujete péči žehličky na vlasy a vosk na vytvoření pramenů."
            },
            "type": "sentence",
            "updated_at": "2016-02-04 15:20:11",
            "created_at": null,
            "status": "published"
          },
          {
            "id": "3881-1_us3",
            "mid": "cs.3881-1_us3",
            "author": "",
            "copyright": null,
            "source": "upraveno http://www.zadov-vancouver2010.cz/?p=68",
            "admin": "https://the.sketchengine.co.uk/bonito/run.cgi/view?q=q[lc%3D%22vosk%22|lemma_lc%3D%22vosk%22]&q=e100+;fromp=3;corpname=preloaded%2Fcztenten12_8&attrs=word&ctxattrs=word&structs=p%2Cg&refs=doc&gdex_enabled=1&gdexconf=&iquery=vosk&attr_tooltip=nott",
            "text": {
              "_text": "Na běh jsme dostali nové lyže z Norska, hole měl každý své, vosky na skluznice byly od finské firmy."
            },
            "type": "sentence",
            "updated_at": "2016-02-04 15:20:11",
            "created_at": null,
            "status": "published"
          }
        ],
        "text": {
          "_text": "tuhá, teplem tvárná a na omak mastná látka organického původu nebo chemicky vyrobená"
        }
      }
    ],
    "collocations": {
      "status": "published"
    }
